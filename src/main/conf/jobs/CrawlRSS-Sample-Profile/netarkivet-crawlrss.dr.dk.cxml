<!-- QUOTA ENFORCER BEAN -->

<bean id="quotaenforcer" 
  class="org.archive.crawler.prefetch.QuotaEnforcer">
  <property name="forceRetire" value="false"></property>

  <property name="serverMaxFetchSuccesses" value="-1"></property>
  <property name="serverMaxSuccessKb" value="-1"></property>
  <property name="serverMaxFetchResponses" value="-1"></property>
  <property name="serverMaxAllKb" value="-1"></property>

  <property name="hostMaxFetchSuccesses" value="-1"></property>
  <property name="hostMaxSuccessKb" value="-1"></property>
  <property name="hostMaxFetchResponses" value="-1"></property>
  <property name="hostMaxAllKb" value="-1"></property>

  <property name="groupMaxFetchSuccesses" value="%{QUOTA_ENFORCER_GROUP_MAX_FETCH_SUCCES_PLACEHOLDER}">
  </property>
  <property name="groupMaxSuccessKb" value="-1"></property>
  <property name="groupMaxFetchResponses" value="-1"></property>
  <property name="groupMaxAllKb" value="%{QUOTA_ENFORCER_MAX_BYTES_PLACEHOLDER}"></property> 
 </bean>

 <!-- 
   REQUIRED STANDARD BEANS
    It will be very rare to replace or reconfigure the following beans.
  -->

 <!-- STATISTICSTRACKER: standard stats/reporting collector -->
 <bean id="statisticsTracker" 
   class="org.archive.crawler.reporting.StatisticsTracker" autowire="byName">
 </bean>
 
 <!-- CRAWLERLOGGERMODULE: shared logging facility -->
 <bean id="loggerModule" 
   class="org.archive.crawler.reporting.CrawlerLoggerModule">
 </bean>
 <!-- SHEETOVERLAYMANAGER (START)
    Manager of sheets of contextual overlays
    Autowired to include any SheetForSurtPrefix or SheetForDecideRuled beans
    -->
    <bean id="sheetOverlaysManager" autowire="byType" class="org.archive.crawler.spring.SheetOverlaysManager">
    </bean>
    <!-- SHEETOVERLAYMANAGER (END) -->

    <!-- OVERLAY SHEETS (START) -->
    <bean id="queuePrecedenceBean" class="org.archive.crawler.frontier.precedence.BaseQueuePrecedencePolicy"/>

    <!-- SETTINGS OVERLAY SHEETS (START) -->
    <bean class="org.archive.crawler.spring.SurtPrefixesSheetAssociation">
        <property name="surtPrefixes">
            <list>
                <value>http://(dk,politiken,</value>
            </list>
        </property>
        <property name="targetSheetNames">
            <list>
                <value>changeUserAgent</value>
            </list>
        </property>
    </bean>
    <bean class="org.archive.crawler.spring.SurtPrefixesSheetAssociation">
        <property name="surtPrefixes">
            <list>
                <value>http://(dk,version2,</value>
                <value>http://(dk,ing,</value>
            </list>
        </property>
        <property name="targetSheetNames">
            <list>
                <value>ipplus</value>
            </list>
        </property>
    </bean>
    <bean class="org.archive.crawler.spring.SurtPrefixesSheetAssociation">
        <property name="surtPrefixes">
            <list>
                <value>http://(com,jwpsrv,videos-cloudfront,</value>
                <value>http://(net,akamaized,</value>
                <value>http://(net,cloudfront,</value>
                <!--<value>http://(com,jwplatform,content,)/videoes/</value>-->
            </list>
        </property>
        <property name="targetSheetNames">
            <list>
                <value>prioritySheet</value>
            </list>
        </property>
    </bean>
    <bean id="changeUserAgent" class="org.archive.spring.Sheet">
        <property name="map">
            <map>
                <entry key="metadata.userAgentTemplate" value="Mozilla/5.0 (compatible; kb.dk_bot; heritrix/3.4.0 +@OPERATOR_CONTACT_URL@) 06b46e292d41a459fb37fd0cc53a4c3e"/>
            </map>
        </property>
    </bean>
    <bean id="ipplus" class="org.archive.spring.Sheet">
        <property name="map">
            <map>
                <entry key="fetchHttp.acceptHeaders" value="Cookie: ipplus=Nuoqu7iAvAxSfOGpiqhtTB7d0iw9mlOH3FLwcFSJgGwsitOayGiKH94P1rS2vJUkfz2GVFaiE3CJ0fJV"/>
            </map>
        </property>
    </bean>
    <bean id="prioritySheet" class="org.archive.spring.Sheet">
        <property name="map">
            <map>
                <entry key="preparer.queueAssignmentPolicy">
                    <ref bean="alternativeQueuePolicy" />
                </entry>
                <entry key="frontier.queuePrecedencePolicy.basePrecedence" value="10" />
                <entry key="alternativeQueuePolicy.forceQueueAssignment" value="highPriorityQueue" />
            </map>
        </property>
    </bean>
    <bean class="org.archive.crawler.spring.DecideRuledSheetAssociation">
        <property name="targetSheetNames">
            <list>
                <value>disableExtractorJS</value>
            </list>
        </property>
        <property name="rules">
            <bean class="org.archive.modules.deciderules.MatchesListRegexDecideRule">
                <property name="decision" value="ACCEPT"/>
                <property name="regexList">
                    <list>
                        <value>.*\?nocache=.*</value>
                        <value>.*\/wp-json\/?$</value>
                        <value>.*\/wp-includes\/$</value>
                        <value>.*\/cart\/?$</value>
                        <value>.*\.min\.js\?.*</value>
                        <value>.*\.min\.css\?.*</value>
                        <value>.*\/wp-json\/wp\/v[0-9]+\/posts$</value>
                        <value>.*\/wp-json\/wp\/v[0-9]+\/media(\/|\?parent).*</value>
                        <value>.*\/wp-json\/wp\/v[0-9]+\/pages\/[0-9]+</value>
                        <value>.*\/wp-json\/.*media.*</value>
                        <value>.*\/wp-json\/wp\/v[0-9]+\/users\/[0-9]+</value>
                        <value>.*\/wp-json\/wp\/v[0-9]+\/types\/.*</value>
                        <value>.*\/wp-json\/wp\/v[0-9]+\/taxonomies\.*</value>
                        <value>.*\/wp-json\/wp\/v[0-9]+\/tags\/.*</value>
                        <value>.*\/wc-blocks-data\.js[^\/]*$</value>
                        <value>.*\/cart-frontend\.js[^\/]*$</value>
                        <value>.*\/blocks-checkout\.js[^\/]*$</value>
                        <value>.*\/woocommerce\/assets\/client\/blocks\/.*</value>
                        <value>.*\/wp-json\/tribe\/(tickets|events)\/v[0-9]\/$</value>
                        <value>.*\/gtag\/js\?.*</value>
                        <value>.*\/events\/202[0-9]-[0-1][0-9]-[0-3][0-9]\/$</value>
                        <value>.*\/_next\/static\/.*</value>
                        <value>.*rest_route=.*</value>
                        <value>.*instagram\.com\/embed\.js</value>
                        <value>.*platform\.twitter\.com\/widgets\.js</value>
                        <value>(?i).*(\/(image|font|static|chunks|app)(?=\/)){3,}.*</value>
                        <value>(?i).*(\/(Billedtekster|elementor|lazyload|includes|js)(?=\/)){3,}.*</value>
                        <value>(?i).*\/search(\/|\?).*</value>
                        <value>.*\/includes\/js\/index\.js</value>
                        <value>(?i).*\/phpMyAdmin\/.*</value>
                        <value>.*\/API\/logging\/.*</value>
                        <value>.*\/API\/register\/.*</value>
                        <value>(?i).*\/catalogsearch(\/|\?).*</value>
                        <value>.*\/wp-json\/semplice\/v1\/frontend</value>
                        <value>.*\/wrapperMessagingWithoutDetection\.js$</value>
                    </list>
                </property>
            </bean>
        </property>
    </bean>
    <bean id="disableExtractorJS" class="org.archive.spring.Sheet">
        <property name="map">
            <map>
                <entry key="extractorJs.enabled" value="false"/>
                <entry key="extractorHtml.extractJavascript" value="false"/>
            </map>
        </property>
    </bean>
    <bean id="alternativeQueuePolicy" class="org.archive.crawler.frontier.HostnameQueueAssignmentPolicy" />
    <!-- SETTINGS OVERLAY SHEETS (END) -->
    <!-- OVERLAY SHEETS (END) -->

 <!-- BDBMODULE: shared BDB-JE disk persistence manager -->
 <bean id="bdb" 
  class="org.archive.bdb.BdbModule">
 </bean>
 
 <!-- BDBCOOKIESTORAGE: disk-based cookie storage for FetchHTTP -->
 <bean id="cookieStorage" 
   class="org.archive.modules.fetcher.BdbCookieStore">
 </bean>
 
 <!-- SERVERCACHE: shared cache of server/host info -->
 <bean id="serverCache" 
   class="org.archive.modules.net.BdbServerCache">
 </bean>

 <!-- CONFIG PATH CONFIGURER: required helper making crawl paths relative
      to crawler-beans.cxml file, and tracking crawl files for web UI -->
 <bean id="configPathConfigurer" 
   class="org.archive.spring.ConfigPathConfigurer">
 </bean>

  <bean id="RssCrawlReport" class="is.landsbokasafn.crawler.rss.RssCrawlReport">
    <property name="rssCrawlController">
      <ref bean="rssCrawlController" />
    </property>
  </bean>

</beans>
